node-linker=hoisted
# Windows + RN Android: optional shorter pnpm store (reduces CMake path length).
# If installs fail with EPERM, remove this line or set via env only on your machine:
#   set PNPM_VIRTUAL_STORE_DIR=D:\.pnpm-store
# virtual-store-dir=D:/.pnpm-store
package-lock=false
shared-workspace-lockfile=true
prefer-workspace-packages=true
link-workspace-packages=true
