{
  "name": "rn-workspace",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "nx": "nx",
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5",
      "@types/react": "19.1.0",
      "@types/react-dom": "19.1.0"
    },
    "patchedDependencies": {
      "react-native-gesture-handler@2.28.0": "patches/react-native-gesture-handler@2.28.0.patch",
      "react-native-reanimated@4.1.7": "patches/react-native-reanimated@4.1.7.patch",
      "react-native-safe-area-context@5.6.2": "patches/react-native-safe-area-context@5.6.2.patch",
      "react-native-screens@4.16.0": "patches/react-native-screens@4.16.0.patch",
      "react-native-worklets@0.5.1": "patches/react-native-worklets@0.5.1.patch"
    }
  },
  "devDependencies": {
    "nx": "^21.0.3",
    "only-allow": "^1.2.2",
    "typescript": "^5.9.3"
  }
}
