{
  "name": "theme",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "packages/theme",
  "sourceRoot": "packages/theme/src",
  "projectType": "application",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run dev",
        "cwd": "packages/theme"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run build",
        "cwd": "packages/theme"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run typecheck",
        "cwd": "packages/theme"
      }
    }
  },
  "tags": []
}
